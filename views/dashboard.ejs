<%- include("partials/head", { title: "Dashboard" }) %>
<%- include("partials/header") %>

<section class="dashboard-grid">
  <div class="panel">
    <span class="eyebrow">Employee</span>
    <h2><%= currentUser.fullName %></h2>
    <p class="muted"><%= currentUser.role %></p>
    <br>
    <% if (error) { %>
    <div class="alert alert-fail"><%= error %></div>
    <% } %>

    <div class="stats-row">
      <div class="stat-card">
        <span>Сценарии в БД</span>
        <strong><%= totalScenarios %></strong>
      </div>
      <div class="stat-card">
        <span>Необходим резултат:</span>
        <strong><%= passThresholdPercentage %>%</strong>
      </div>
    </div>

    <div class="action-row">
      <% if (activeSession && activeSession.status === "in_progress") { %>
      <a href="/test/current" class="secondary-button">Възобнови текущия тест</a>
      <% } %>

      <form method="post" action="/test/start">
        <button type="submit" class="primary-button">Започни нов тест</button>
      </form>
    </div>
  </div>

  <div class="panel">
    <span class="eyebrow">Latest report</span>
    <% if (latestReport) { %>
    <h2><%= latestReport.passed ? "Успешно преминат" : "Неуспешен опит" %></h2>
    <p>
      Последният тест е с <%= latestReport.correctAnswers %>/<%= latestReport.totalScenarios %>
      правилни отговори и риск индекс от <%= latestReport.riskPercentage %>%.
    </p>
    <a href="/report" class="ghost-link">Отвори report</a>
    <% } else { %>
    <h2>Все още няма завършен тест</h2>
    <p>Стартирай първата симулация и ще получиш финален report тук.</p>
    <% } %>
  </div>
</section>

<%- include("partials/footer") %>
