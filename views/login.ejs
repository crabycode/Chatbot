<%- include("partials/head", { title: "Login" }) %>
<%- include("partials/header") %>

<section class="auth-layout">
  <div class="hero-copy">
    <h2>Обучи служителите си да разпознават атаки от тип социално инженерство чрез реалистичен чат със CYBREACH</h2>
    <p>
      След вход в системата всеки служител преминава през серия от чат сценарии, а системата отчита резултатите, броя правилни решения и общия риск индекс.
    </p>

    <div class="info-panel">
      <h3>Как да влезете?</h3>
      <p><strong>Потребителско име:</strong> [име].[фамилия]</p>
      <p><strong>Парола:</strong> [предоставената ви парола]</p>
    </div>
  </div>

  <div class="panel auth-panel">
    <div class="panel-heading">
      <h2>Вход в тестовата платформа</h2>
    </div>

    <% if (error) { %>
    <div class="alert alert-fail"><%= error %></div>
    <% } %>

    <form method="post" action="/login" class="form-stack">
      <label>
        <span>Потребителско име:</span>
        <input type="text" name="username" placeholder="worker1" autocomplete="username" required />
      </label>

      <label>
        <span>Парола:</span>
        <div class="password-input-wrap">
          <input
            id="login-password"
            type="password"
            name="password"
            placeholder="TrainMe123!"
            autocomplete="current-password"
            required
          />
          <button
            type="button"
            class="password-toggle"
            data-password-toggle="#login-password"
            aria-label="Покажи паролата"
            aria-pressed="false"
          >
            <svg
              viewBox="0 0 24 24"
              class="password-toggle-icon"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M1.5 12S5.5 5.5 12 5.5 22.5 12 22.5 12 18.5 18.5 12 18.5 1.5 12 1.5 12Z" />
              <circle cx="12" cy="12" r="3.2" />
              <path class="password-toggle-slash" d="M4 20 20 4" />
            </svg>
          </button>
        </div>
      </label>

      <button type="submit" class="primary-button">Влез и стартирай обучение</button>
    </form>
  </div>
</section>

<script src="/static/passwordToggle.js"></script>
<%- include("partials/footer") %>
