<%- include("partials/head", { title: "Test" }) %>
<%- include("partials/test-header", {
  scenarioTitle: view.scenarioTitle,
  currentIndex: view.currentIndex,
  totalScenarios: view.totalScenarios,
  completedCount: view.currentIndex - 1,
}) %>

<section class="simulator-layout">
  <section class="chat-shell">
    <header class="chat-header">
      <div>
        <span class="eyebrow">Live chat simulation</span>
        <h2><%= view.personaName %> <span class="muted">(<%= view.personaRole %>)</span></h2>
      </div>
    </header>

    <div
      class="chat-feed"
      data-typing-feed
      data-conversation-key="<%= `${view.testAttemptKey}-${view.currentIndex}-${view.scenarioTitle}` %>"
    >
      <% for (const message of view.conversation) { %>
      <article class="message <%= message.direction %> is-pending" data-chat-message>
        <span class="message-author"><%= message.speaker %></span>
        <div class="message-bubble"><%= message.text %></div>
      </article>
      <% } %>
    </div>

    <form method="post" action="/test/answer" class="choices-grid is-waiting" data-chat-choices>
      <% for (const option of view.options) { %>
      <button type="submit" name="optionId" value="<%= option.id %>" class="choice-card">
        <span class="choice-key"><%= option.choiceKey %></span>
        <span><%= option.label %></span>
      </button>
      <% } %>
    </form>
  </section>
</section>

<script src="/static/chatTyping.js"></script>
<%- include("partials/footer") %>
